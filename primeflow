#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if ! command -v node >/dev/null 2>&1; then
  echo "PrimeFlow requires Node.js (>=18)." >&2
  exit 1
fi

if [ "$PWD" = "$SCRIPT_DIR" ] && [ -d "$SCRIPT_DIR/.git" ]; then
  exec node "$SCRIPT_DIR/bin/primeflow.mjs" --project-root "$SCRIPT_DIR" "$@"
fi

exec node "$SCRIPT_DIR/bin/primeflow.mjs" "$@"
